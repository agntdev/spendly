[
  {
    "name": "log an expense via quick categories button flow with note skip",
    "steps": [
      {
        "send": { "callback": "quick:log" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": { "text": "Enter the expense amount:" }
          }
        ]
      },
      {
        "send": { "text": "12.50" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "Add a note? (send text or tap Skip)" }
          }
        ]
      },
      {
        "send": { "callback": "quick:skip_note" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": { "text": "Amount: $12.50. Pick a category:" }
          }
        ]
      },
      {
        "send": { "callback": "quick:add_amount:id2" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": { "text": "Expense logged: $12.50 in Transport" }
          }
        ]
      },
      {
        "send": { "callback": "quick:undo:id12" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": { "text": "Expense undone." }
          }
        ]
      }
    ]
  },
  {
    "name": "log an expense via quick categories button flow with note text",
    "steps": [
