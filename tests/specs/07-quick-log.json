          }
        ]
      },
      {
        "send": { "callback": "quick:category:id3" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": { "text": "Enter the amount for Housing:" }
          }
        ]
      },
      {
        "send": { "text": "25.00" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "Add a note? (send text or tap Skip)" }
          }
        ]
      },
      {
        "send": { "callback": "quick:skip_note" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": { "text": "Expense logged: $25.00 in Housing" }
          }
        ]
      }
    ]
  }
]